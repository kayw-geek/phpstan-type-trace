#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * phpstan-trace — query the type-inference chain of a variable.
 *
 * Usage:
 *   phpstan-trace inspect <file>:<line> <var> [--json] [--phpstan=<path>] [--cwd=<dir>]
 *
 * The variable name may include `->` and `::` chains (e.g. `user->name`).
 * A leading `$` is optional. The CLI returns the chain of events that
 * shaped this variable up to and including <line>.
 */

use function Termwind\render;

const SENTINEL = '__TYPETRACE_DUMP__';

bootstrapAutoload();
main($argv);

function bootstrapAutoload(): void
{
    foreach ([
        __DIR__ . '/../../../autoload.php',  // installed under vendor/
        __DIR__ . '/../vendor/autoload.php', // running from source checkout
    ] as $candidate) {
        if (is_file($candidate)) {
            require $candidate;
            return;
        }
    }
    fwrite(STDERR, "Could not locate composer autoload.php\n");
    exit(1);
}

function main(array $argv): void
{
    $argv = array_values(array_slice($argv, 1));
    $cmd = $argv[0] ?? null;

    if ($cmd === null || $cmd === '-h' || $cmd === '--help' || $cmd === 'help') {
        usage(STDOUT);
        exit($cmd === null ? 1 : 0);
    }

    if ($cmd !== 'inspect') {
        fwrite(STDERR, "Unknown command: {$cmd}\n\n");
        usage(STDERR);
        exit(1);
    }

    [$positional, $options] = parseArgs(array_slice($argv, 1));

    if (count($positional) < 1 || count($positional) > 2) {
        fwrite(STDERR, "inspect requires <file>:<line> and an optional <var>\n\n");
        usage(STDERR);
        exit(1);
    }

    $fileLine = $positional[0];
    $rawVar = $positional[1] ?? null;
    if (!preg_match('/^(.+):(\d+)$/', $fileLine, $m)) {
        fwrite(STDERR, "Expected <file>:<line>, got: {$fileLine}\n");
        exit(1);
    }

    $cwd = $options['cwd'] ?? getcwd();
    $file = $m[1];
    $line = (int) $m[2];

    $absFile = resolveFile($file, $cwd);
    if ($absFile === null) {
        fwrite(STDERR, "File not found: {$file}\n");
        exit(1);
    }

    $phpstanBin = $options['phpstan'] ?? findPhpstan($cwd);
    if ($phpstanBin === null) {
        fwrite(STDERR, "Could not locate phpstan binary. Pass --phpstan=<path>.\n");
        exit(1);
    }

    $chains = runDump($phpstanBin, $absFile, $cwd);
    $json = !empty($options['json']);

    if ($rawVar === null) {
        $candidates = candidatesAtLine($chains, $absFile, $line);
        if (count($candidates) === 1) {
            $path = $candidates[0];
        } else {
            renderAmbiguous($candidates, $absFile, $line, $cwd, $json);
            exit($json ? 0 : 2);
        }
    } else {
        $path = normalizeVarPath($rawVar);
    }

    $match = pickChain($chains, $absFile, $path, $line);

    if ($match === null) {
        $reason = diagnoseMiss($chains, $absFile, $path);
        if ($json) {
            echo json_encode([
                'found' => false,
                'file' => $absFile,
                'line' => $line,
                'path' => $path,
                'reason' => $reason['code'],
                'message' => $reason['message'],
                'availablePaths' => $reason['availablePaths'],
            ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT), "\n";
        } else {
            renderMissPretty(STDERR, $path, $absFile, $line, $reason, $cwd);
        }
        exit($json ? 0 : 2);
    }

    if ($json) {
        echo json_encode([
            'found' => true,
            'file' => $absFile,
            'line' => $line,
            'path' => $match['path'],
            'functionKey' => $match['functionKey'],
            'chain' => $match['chain'],
        ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT), "\n";
    } else {
        renderChainPretty($match, $line, $cwd);
    }
}

function usage($stream): void
{
    fwrite($stream, <<<'TXT'
phpstan-trace — inspect the type-inference chain of a PHP variable.

Usage:
  phpstan-trace inspect <file>:<line> [<var>] [options]

Arguments:
  <file>:<line>   Target location, e.g. src/Service.php:42
  <var>           Variable to inspect (optional). Accepts (always single-quote
                  any form except a bare name — the shell will otherwise
                  expand $, redirect on >, or split on ;):
                    user             → $user
                    '$user'          → $user
                    'user->name'     → $user->name
                    '$user->name'    → $user->name
                    'self::$count'   → self::$count
                    'Foo::$count'    → Foo::$count
                  If omitted and exactly one variable is tracked at <line>,
                  it is auto-selected. Otherwise the candidates are listed.

Options:
  --json          Emit machine-readable JSON (designed for agent consumption).
  --phpstan=PATH  Override phpstan binary (default: ./vendor/bin/phpstan).
  --cwd=DIR       Override working directory used to resolve paths.
  -h, --help      Show this message.

Examples:
  phpstan-trace inspect src/User.php:42 user --json
  phpstan-trace inspect src/User.php:55 user->profile

TXT
    );
}

/**
 * @return array{0: list<string>, 1: array<string, string|true>}
 */
function parseArgs(array $args): array
{
    $positional = [];
    $options = [];
    foreach ($args as $arg) {
        if (str_starts_with($arg, '--')) {
            $body = substr($arg, 2);
            if (str_contains($body, '=')) {
                [$k, $v] = explode('=', $body, 2);
                $options[$k] = $v;
            } else {
                $options[$body] = true;
            }
        } else {
            $positional[] = $arg;
        }
    }
    return [$positional, $options];
}

function resolveFile(string $file, string $cwd): ?string
{
    if ($file !== '' && $file[0] === '/' && is_file($file)) {
        return realpath($file) ?: $file;
    }
    $abs = $cwd . DIRECTORY_SEPARATOR . $file;
    if (is_file($abs)) {
        return realpath($abs) ?: $abs;
    }
    return null;
}

function normalizeVarPath(string $raw): string
{
    if ($raw === '') {
        return $raw;
    }
    // Allow leading $ to be optional for plain variables.
    if ($raw[0] !== '$' && !str_starts_with($raw, 'self::') && !str_starts_with($raw, 'static::') && !str_contains($raw, '::')) {
        return '$' . $raw;
    }
    return $raw;
}

function findPhpstan(string $cwd): ?string
{
    $candidates = [
        $cwd . '/vendor/bin/phpstan',
        $cwd . '/vendor/bin/phpstan.phar',
    ];
    foreach ($candidates as $c) {
        if (is_file($c) && is_executable($c)) {
            return $c;
        }
    }
    return null;
}

/**
 * @return list<array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>}>
 */
function runDump(string $phpstanBin, string $absFile, string $cwd): array
{
    $cmd = sprintf(
        '%s analyse --error-format=json --no-progress %s',
        escapeshellarg($phpstanBin),
        escapeshellarg($absFile),
    );
    $descriptors = [
        0 => ['pipe', 'r'],
        1 => ['pipe', 'w'],
        2 => ['pipe', 'w'],
    ];
    $env = array_merge($_ENV, getenv(), ['PHPSTAN_TYPE_TRACE_DUMP' => '1']);
    $proc = proc_open($cmd, $descriptors, $pipes, $cwd, $env);
    if (!is_resource($proc)) {
        fwrite(STDERR, "Failed to spawn phpstan\n");
        exit(1);
    }
    fclose($pipes[0]);
    $stdout = stream_get_contents($pipes[1]);
    fclose($pipes[1]);
    $stderr = stream_get_contents($pipes[2]);
    fclose($pipes[2]);
    proc_close($proc);

    $data = json_decode($stdout, true);
    if (!is_array($data) || !isset($data['files'])) {
        fwrite(STDERR, "phpstan did not return JSON. stderr:\n{$stderr}\n");
        exit(1);
    }

    $chains = [];
    foreach ($data['files'] as $file => $info) {
        foreach (($info['messages'] ?? []) as $msg) {
            $text = $msg['message'] ?? '';
            if (!str_starts_with($text, SENTINEL)) {
                continue;
            }
            $payload = json_decode(substr($text, strlen(SENTINEL)), true);
            if (!is_array($payload) || ($payload['_typetrace'] ?? false) !== true) {
                continue;
            }
            $chains[] = [
                'file' => $file,
                'functionKey' => $payload['functionKey'],
                'path' => $payload['path'],
                'chain' => $payload['chain'],
                'eventLines' => $payload['eventLines'] ?? array_values(array_unique(array_map(
                    static fn (array $e): int => $e['line'],
                    $payload['chain'],
                ))),
            ];
        }
    }
    return $chains;
}

/**
 * @param list<array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>}> $chains
 * @return array{code:string, message:string, availablePaths:list<string>}
 */
function diagnoseMiss(array $chains, string $absFile, string $path): array
{
    if ($chains === []) {
        return [
            'code' => 'extension_not_loaded',
            'message' => 'phpstan emitted zero trace events. The extension is likely not registered. '
                . 'Ensure phpstan/extension-installer is installed, or include extension.neon manually in phpstan.neon.',
            'availablePaths' => [],
        ];
    }

    $sameFile = array_values(array_filter($chains, static fn (array $c): bool => $c['file'] === $absFile));
    if ($sameFile === []) {
        $files = array_values(array_unique(array_map(static fn (array $c): string => $c['file'], $chains)));
        return [
            'code' => 'file_path_mismatch',
            'message' => 'No chains recorded for ' . $absFile . '. phpstan reported chains for other files: '
                . implode(', ', array_slice($files, 0, 3)) . (count($files) > 3 ? ', ...' : ''),
            'availablePaths' => [],
        ];
    }

    $paths = array_values(array_unique(array_map(static fn (array $c): string => $c['path'], $sameFile)));
    return [
        'code' => 'path_not_tracked',
        'message' => 'No events recorded for ' . $path . ' in this file. '
            . 'The variable may be array-dim only ($x[] = ...), dynamic, or defined after the queried line.',
        'availablePaths' => $paths,
    ];
}

/**
 * @param list<array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>}> $chains
 * @return array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>}|null
 */
function pickChain(array $chains, string $absFile, string $path, int $line): ?array
{
    $best = null;
    foreach ($chains as $candidate) {
        if ($candidate['file'] !== $absFile) {
            continue;
        }
        if ($candidate['path'] !== $path) {
            continue;
        }
        $trimmed = array_values(array_filter(
            $candidate['chain'],
            static fn (array $e): bool => $e['line'] <= $line,
        ));
        if ($trimmed === []) {
            continue;
        }
        $lastLine = $trimmed[count($trimmed) - 1]['line'];
        if ($best === null || $lastLine > $best['_lastLine']) {
            $best = [
                'file' => $candidate['file'],
                'functionKey' => $candidate['functionKey'],
                'path' => $candidate['path'],
                'chain' => $trimmed,
                '_lastLine' => $lastLine,
            ];
        }
    }
    if ($best === null) {
        return null;
    }
    unset($best['_lastLine']);
    return $best;
}

/**
 * Turn `{absFile}::{fn}` into a human label: `fn  [basename]` or `(file scope) [basename]`.
 */
function formatFnLabel(string $functionKey, string $cwd): string
{
    $sep = '::';
    $pos = strrpos($functionKey, $sep);
    if ($pos === false) {
        return $functionKey;
    }
    $file = substr($functionKey, 0, $pos);
    $fn = substr($functionKey, $pos + strlen($sep));
    $rel = str_starts_with($file, $cwd . DIRECTORY_SEPARATOR)
        ? substr($file, strlen($cwd) + 1)
        : basename($file);
    if ($fn === '__top__') {
        return "(file scope) [{$rel}]";
    }
    return "{$fn}  [{$rel}]";
}

function originColor(string $origin): string
{
    return match ($origin) {
        'param'                                            => 'text-green',
        'assign', 'assign-op', 'assign-ref', 'array-write' => 'text-yellow',
        default                                            => 'text-gray',  // read
    };
}

/**
 * @param array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>} $match
 */
function renderChainPretty(array $match, int $line, string $cwd): void
{
    $maxOrigin = 0;
    foreach ($match['chain'] as $e) {
        $maxOrigin = max($maxOrigin, strlen($e['origin']));
    }
    $maxLine = 0;
    foreach ($match['chain'] as $e) {
        $maxLine = max($maxLine, strlen((string) $e['line']));
    }

    $path = htmlentities($match['path']);
    $label = htmlentities(formatFnLabel($match['functionKey'], $cwd));
    $upTo = "L{$line}";

    render(<<<HTML
        <div class="mt-1">
            <span class="text-cyan font-bold">{$path}</span>
            <span class="text-gray ml-1">·</span>
            <span class="text-gray ml-1">{$label}</span>
            <span class="text-gray ml-1">(up to {$upTo})</span>
        </div>
    HTML);
    render('<hr class="text-gray" />');

    $lineWidth = $maxLine + 1; // include the leading 'L'
    $originWidth = $maxOrigin;
    foreach ($match['chain'] as $event) {
        $color = originColor($event['origin']);
        $type = htmlentities($event['type']);
        $lineLabel = 'L' . $event['line'];
        $origin = $event['origin'];
        render(<<<HTML
            <div class="pl-2">
                <span class="text-gray w-{$lineWidth}">{$lineLabel}</span>
                <span class="{$color} ml-2 w-{$originWidth}">{$origin}</span>
                <span class="ml-2">{$type}</span>
            </div>
        HTML);
    }

    render('<hr class="text-gray" />');

    $count = count($match['chain']);
    $word = $count === 1 ? 'event' : 'events';
    $final = htmlentities($match['chain'][$count - 1]['type']);
    render(<<<HTML
        <div class="mb-1">
            <span class="text-gray">{$count} {$word} · final type:</span>
            <span class="text-cyan ml-1">{$final}</span>
        </div>
    HTML);
}

/**
 * @param array{code:string, message:string, availablePaths:list<string>} $reason
 */
function renderMissPretty($stream, string $path, string $absFile, int $line, array $reason, string $cwd): void
{
    $rel = str_starts_with($absFile, $cwd . DIRECTORY_SEPARATOR)
        ? substr($absFile, strlen($cwd) + 1)
        : $absFile;

    $pathHtml = htmlentities($path);
    $whereHtml = htmlentities("{$rel}:{$line}");
    $code = htmlentities($reason['code']);
    $message = htmlentities($reason['message']);

    render(<<<HTML
        <div class="mt-1">
            <span class="bg-red text-white px-1 font-bold">No chain</span>
            <span class="ml-1 text-cyan">{$pathHtml}</span>
            <span class="ml-1 text-gray">at</span>
            <span class="ml-1 text-cyan">{$whereHtml}</span>
        </div>
    HTML);
    render(<<<HTML
        <div>
            <span class="text-yellow font-bold">Reason</span>
            <span class="text-gray ml-1">({$code}):</span>
            <span class="ml-1">{$message}</span>
        </div>
    HTML);

    if ($reason['availablePaths'] !== []) {
        $list = htmlentities(implode(', ', $reason['availablePaths']));
        render(<<<HTML
            <div class="mb-1">
                <span class="text-green font-bold">Tracked in this file:</span>
                <span class="ml-1">{$list}</span>
            </div>
        HTML);
    }
}

/**
 * Return the distinct variable paths that have at least one raw event at
 * exactly the queried line in the queried file. Uses pre-dedup `eventLines`
 * so reads collapsed by the chain builder still count as candidates.
 *
 * @param list<array{file:string, functionKey:string, path:string, chain:list<array{line:int,origin:string,type:string}>, eventLines:list<int>}> $chains
 * @return list<string>
 */
function candidatesAtLine(array $chains, string $absFile, int $line): array
{
    $paths = [];
    foreach ($chains as $candidate) {
        if ($candidate['file'] !== $absFile) {
            continue;
        }
        if (in_array($line, $candidate['eventLines'], true)) {
            $paths[$candidate['path']] = true;
        }
    }
    return array_values(array_keys($paths));
}

/**
 * Render the disambiguation output when <var> is omitted and we cannot
 * auto-pick a single candidate (zero, or more than one).
 *
 * @param list<string> $candidates
 */
function renderAmbiguous(array $candidates, string $absFile, int $line, string $cwd, bool $json): void
{
    if ($json) {
        echo json_encode([
            'found' => false,
            'file' => $absFile,
            'line' => $line,
            'reason' => $candidates === [] ? 'no_var_at_line' : 'ambiguous',
            'message' => $candidates === []
                ? 'No tracked variable has an event at this line.'
                : 'Multiple variables are tracked at this line; specify <var>.',
            'candidates' => $candidates,
        ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT), "\n";
        return;
    }

    $rel = str_starts_with($absFile, $cwd . DIRECTORY_SEPARATOR)
        ? substr($absFile, strlen($cwd) + 1)
        : $absFile;
    $whereHtml = htmlentities("{$rel}:{$line}");

    if ($candidates === []) {
        render(<<<HTML
            <div class="mt-1">
                <span class="bg-red text-white px-1 font-bold">No variable</span>
                <span class="ml-1 text-gray">at</span>
                <span class="ml-1 text-cyan">{$whereHtml}</span>
            </div>
        HTML);
        render(<<<HTML
            <div class="mb-1">
                <span class="text-yellow">No tracked variable has an event at this line. Pass</span>
                <span class="text-cyan ml-1">&lt;var&gt;</span>
                <span class="text-yellow ml-1">explicitly, or pick another line.</span>
            </div>
        HTML);
        return;
    }

    render(<<<HTML
        <div class="mt-1">
            <span class="bg-yellow text-black px-1 font-bold">Ambiguous</span>
            <span class="ml-1 text-gray">at</span>
            <span class="ml-1 text-cyan">{$whereHtml}</span>
            <span class="ml-1 text-gray">— multiple variables tracked, pick one:</span>
        </div>
    HTML);
    foreach ($candidates as $cand) {
        $candHtml = htmlentities($cand);
        render(<<<HTML
            <div class="pl-2">
                <span class="text-gray">•</span>
                <span class="text-cyan ml-1">{$candHtml}</span>
            </div>
        HTML);
    }
    render('<div class="mb-1"></div>');
}
