{
    "name": "kayw-geek/phpstan-type-trace",
    "description": "Visualize the full type-inference chain of a value in PHPStan analysis output.",
    "type": "phpstan-extension",
    "license": "MIT",
    "keywords": ["phpstan", "static-analysis", "debug", "types"],
    "bin": ["bin/phpstan-trace"],
    "require": {
        "php": "^8.1",
        "phpstan/phpstan": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kayw\\PhpstanTypeTrace\\": "src/"
        },
        "files": [
            "src/runtime.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kayw\\PhpstanTypeTrace\\Tests\\": "tests/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
